# Supabase — find these in your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Set to "true" to query Supabase instead of the built-in sample data.
# Leave as "false" (or unset) to run entirely with mock data — no Supabase needed.
NEXT_PUBLIC_USE_LIVE_DATA=false
