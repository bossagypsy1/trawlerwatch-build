# Supabase — find these in your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
AIS_INTERNAL_URL=http://mcutk9oc0aoc2n59ajaugkhr.157.180.125.240.sslip.io/status

# Required for Basic Baked Users Auth
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Optional for local/dev because the app has a baked fallback.
# Required before commercial/production use.
NEXTAUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=http://localhost:3030

# Set to "true" to query Supabase instead of the built-in sample data.
# Leave as "false" (or unset) to run entirely with mock data — no Supabase needed.
NEXT_PUBLIC_USE_LIVE_DATA=false
